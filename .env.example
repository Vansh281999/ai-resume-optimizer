# AI Provider API Keys (at least one required)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# Ollama runs locally; leave empty if using local default
OLLAMA_API_KEY=
OLLAMA_BASE_URL=

# CrewAI tools
SERPER_API_KEY=

# Runtime - REQUIRED on Render
SECRET_KEY=generate-with-python-secrets.token_urlsafe32
DATABASE_URL=sqlite:///./career_platform.db
DEBUG=false
LOG_LEVEL=INFO

# CORS - Comma-separated list of allowed origins
# Required for GitHub Pages to access Render backend
CORS_ORIGINS=https://vansh281999.github.io,https://ai-resume-optimizer-dium.onrender.com
